# ──────────────────────────────────────────────────────────────────────────────
# CouchChain — Variables de entorno (plantilla SIN secretos reales)
# Copiar como .env.local y completar. NUNCA commitear .env.local
# Guía: docs/REGISTROS-Y-APIS.md
# ──────────────────────────────────────────────────────────────────────────────

# IA
GROQ_API_KEY=

# Photon — geocodificación (GeoJSON FeatureCollection)
# Base típica con ?q= al final; el código concatena el texto de búsqueda (URL-encoded).
PHOTON_BASE_URL=https://photon.komoot.io/api/?q=
# PHOTON_LIMIT=
# PHOTON_LANG=es

# Enrutamiento servidor (OSRM/compatible) — SOLO base, sin coordenadas
ROUTING_BASE_URL=https://router.project-osrm.org/route/v1/driving
# OSRM_BASE_URL=https://router.project-osrm.org

# Leaflet Routing Machine (cliente)
NEXT_PUBLIC_LEAFLET_ROUTING_SERVICE_URL=https://router.project-osrm.org/route/v1
# NEXT_PUBLIC_USE_LEAFLET_ROUTING_MACHINE=true

# GraphHopper (fallback servidor)
GRAPHHOPPER_API_KEY=
# GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1

# SerpAPI — precios reales N3 (Google Flights API de SerpAPI). Requiere que el usuario
# indique aeropuertos IATA en el mensaje (ej. «de ROS a BRC»); ver docs/REGISTROS-Y-APIS.md
SERPAPI_API_KEY=
# SERPAPI_GL=ar
# SERPAPI_HL=es

# Forzar datos demo en el worker aunque exista SERPAPI_API_KEY
# SCRAPER_FORCE_STUB=true

AVIATIONSTACK_API_KEY=

TRANSITLAND_API_KEY=

# Redis (BullMQ — cola scrape-prices). Upstash: usar REDIS_URL rediss://...
REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# IPFS (Pinata) — solo servidor
PINATA_JWT=
PINATA_GATEWAY_URL=gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY_URL=gateway.pinata.cloud

# Etherlink
NEXT_PUBLIC_ETHERLINK_RPC_URL=https://node.shadownet.etherlink.com
NEXT_PUBLIC_ETHERLINK_CHAIN_ID=128123
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_TRUST_REGISTRY_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_ECC=
SUPABASE_JWT_HS256=
DATABASE_URL=

# Email (opcional)
# RESEND_API_KEY=
# EMAIL_FROM=

# TWO_CAPTCHA_API_KEY=
# GOOGLE_MAPS_API_KEY=
# KIWI_API_KEY=
