# ──────────────────────────────────────────────────────────────────────────────
# CouchChain — Variables de entorno (plantilla SIN secretos reales)
# Copiar como .env.local y completar. NUNCA commitear .env.local
# Guía: docs/REGISTROS-Y-APIS.md
# ──────────────────────────────────────────────────────────────────────────────

# IA
GROQ_API_KEY=

# Photon — geocodificación (GeoJSON FeatureCollection)
# Base típica con ?q= al final; el código concatena el texto de búsqueda (URL-encoded).
# Ejemplo: PHOTON_BASE_URL=https://photon.komoot.io/api/?q=
# Opcional: PHOTON_LIMIT=5  PHOTON_LANG=es
PHOTON_BASE_URL=https://photon.komoot.io/api/?q=
# PHOTON_LIMIT=
# PHOTON_LANG=es

# Enrutamiento servidor (OSRM/compatible) — SOLO base, sin coordenadas
# El código añade: /{lng},{lat};{lng},{lat}?overview=full&geometries=geojson&steps=false
# Ejemplo: ROUTING_BASE_URL=https://router.project-osrm.org/route/v1/driving
# Si vacío, se usa el mismo host por defecto.
ROUTING_BASE_URL=https://router.project-osrm.org/route/v1/driving
# Legado (opcional): si ROUTING_BASE_URL no está definido en .env antiguo
# OSRM_BASE_URL=https://router.project-osrm.org

# Leaflet Routing Machine (cliente) — servicio OSRM v1 público
# Debe coincidir con el host que uses en el mapa (sin el sufijo /driving/...)
NEXT_PUBLIC_LEAFLET_ROUTING_SERVICE_URL=https://router.project-osrm.org/route/v1
# false = dibujar solo polyline del servidor; true (default) = leaflet-routing-machine + OSRM público
# NEXT_PUBLIC_USE_LEAFLET_ROUTING_MACHINE=true

# GraphHopper (fallback si OSRM falla o sin instancia propia)
# También se acepta GRASSHOPPER_API_KEY por compatibilidad con nombres previos
GRAPHHOPPER_API_KEY=
# GRASSHOPPER_API_KEY=
# GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1

# APIs opcionales de enriquecimiento
SERPAPI_API_KEY=
AVIATIONSTACK_API_KEY=

TRANSITLAND_API_KEY=

# Scraping async (Nivel 3)
REDIS_URL=

# IPFS (Pinata) — solo servidor
PINATA_JWT=
PINATA_GATEWAY_URL=gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY_URL=gateway.pinata.cloud

# Etherlink
NEXT_PUBLIC_ETHERLINK_RPC_URL=https://node.shadownet.etherlink.com
NEXT_PUBLIC_ETHERLINK_CHAIN_ID=128123
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_TRUST_REGISTRY_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# Supabase — cliente público + secreto servidor + Postgres (Prisma)
# URL del proyecto: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Referencias JWT del dashboard (Edge/Auth avanzado; opcional)
SUPABASE_JWT_ECC=
SUPABASE_JWT_HS256=
# Cadena Postgres de Supabase (Settings → Database) para Prisma migrate
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Email (opcional)
# RESEND_API_KEY=
# EMAIL_FROM=

# TWO_CAPTCHA_API_KEY=

# GOOGLE_MAPS_API_KEY=
# KIWI_API_KEY=
