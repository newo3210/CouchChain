# ──────────────────────────────────────────────────────────────────────────────
# CouchChain — Variables de entorno (plantilla SIN secretos reales)
# Copiar como .env.local y completar. NUNCA commitear .env.local
# Guía: docs/REGISTROS-Y-APIS.md
# Actor Apify (misma clave): Settings → Secrets → SERPAPI_API_KEY
# ──────────────────────────────────────────────────────────────────────────────

# IA
GROQ_API_KEY=

# Photon
PHOTON_BASE_URL=https://photon.komoot.io/api/?q=
# PHOTON_LIMIT=
# PHOTON_LANG=es

ROUTING_BASE_URL=https://router.project-osrm.org/route/v1/driving
# OSRM_BASE_URL=

NEXT_PUBLIC_LEAFLET_ROUTING_SERVICE_URL=https://router.project-osrm.org/route/v1
# NEXT_PUBLIC_USE_LEAFLET_ROUTING_MACHINE=true

GRAPHHOPPER_API_KEY=
# GRAPHHOPPER_BASE_URL=https://graphhopper.com/api/1

# SerpAPI — N3 precios (worker local y lógica equivalente en Actor Apify)
SERPAPI_API_KEY=
# SERPAPI_GL=ar
# SERPAPI_HL=es
# SCRAPER_FORCE_STUB=true

AVIATIONSTACK_API_KEY=

TRANSITLAND_API_KEY=

REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Apify — N3 por Actor en la nube (opcional). Si APIFY_API_TOKEN y APIFY_ACTOR_ID
# están definidos, CouchChain encola vía API Apify y ya no usa BullMQ para ese paso.
# Token: Consola Apify → Settings → Integrations → API token.
# Actor id: tu_usuario~nombre-del-actor (ej. newo3210~couchchain-price-scraper)
APIFY_API_TOKEN=
# APIFY_TOKEN=
APIFY_ACTOR_ID=

PINATA_JWT=
PINATA_GATEWAY_URL=gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY_URL=gateway.pinata.cloud

NEXT_PUBLIC_ETHERLINK_RPC_URL=https://node.shadownet.etherlink.com
NEXT_PUBLIC_ETHERLINK_CHAIN_ID=128123
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_TRUST_REGISTRY_ADDRESS=
DEPLOYER_PRIVATE_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_ECC=
SUPABASE_JWT_HS256=
DATABASE_URL=

# RESEND_API_KEY=
# EMAIL_FROM=
# TWO_CAPTCHA_API_KEY=
# GOOGLE_MAPS_API_KEY=
# KIWI_API_KEY=
