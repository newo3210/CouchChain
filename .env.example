# ──────────────────────────────────────────────────────────────────────────────
# CouchChain — Variables de entorno
# Copiar como .env.local y completar los valores reales.
# NUNCA commitear .env.local ni exponer secretos al cliente.
# Guía completa: docs/REGISTROS-Y-APIS.md
# ──────────────────────────────────────────────────────────────────────────────

# IA ──────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# Geocoding / routing (Nivel 0 — sin costo)
# Dejar vacío para usar endpoints públicos por defecto
PHOTON_BASE_URL=
OSRM_BASE_URL=

# Transporte público (Nivel 2)
TRANSITLAND_API_KEY=

# Scraping async (Nivel 3)
REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# IPFS (Pinata) — solo servidor
PINATA_JWT=
PINATA_GATEWAY_URL=gateway.pinata.cloud
# Exponer a cliente para construir URLs de visualización
NEXT_PUBLIC_PINATA_GATEWAY_URL=gateway.pinata.cloud

# Etherlink ───────────────────────────────────────────────────────────────────
# Verificar RPC y chain ID vigentes en: https://docs.etherlink.com
NEXT_PUBLIC_ETHERLINK_RPC_URL=https://node.shadownet.etherlink.com
NEXT_PUBLIC_ETHERLINK_CHAIN_ID=128123

# Contratos desplegados (generados por contracts/ignition/modules/deploy.ts)
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_TRUST_REGISTRY_ADDRESS=

# Clave del deployer (solo para deploy de contratos, nunca en producción web)
DEPLOYER_PRIVATE_KEY=

# Base de datos ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/couchchain

# Email transaccional (opcional — Puente de Confianza)
# RESEND_API_KEY=
# EMAIL_FROM=hola@couchchain.xyz

# CAPTCHA solver (solo si el scraper lo requiere)
# TWO_CAPTCHA_API_KEY=

# APIs de pago opcionales (enriquecimiento; no son el stack default del Blueprint)
# GOOGLE_MAPS_API_KEY=
# KIWI_API_KEY=
